{
  "name": "the-universe",
  "version": "1.0.0",
  "description": "3D Interactive Space Exploration Application",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "mkdir -p dist && cp index.html dist/ && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "latest",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
